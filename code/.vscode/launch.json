{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
        },
        {
            "name": "Python FastAPI",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "${relativeFileDirname}.${fileBasenameNoExtension}:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "jinja": true,
        }
    ]
}